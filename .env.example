# ── Copy this file to .env and fill in your values ───────────────────────────

# Video source: file path, RTSP URL, or webcam index (0)
VIDEO_SOURCE=sample_video.mp4

# Database (SQLite for dev, PostgreSQL for prod)
DB_URL=sqlite:///./parkpulse.db
# DB_URL=postgresql://user:password@localhost:5432/parkpulse

# JWT — generate a strong secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Razorpay (leave blank to use demo/mock payment mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Pricing default
PRICE_PER_HOUR_INR=50.0

# Logging
LOG_LEVEL=INFO
